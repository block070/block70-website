POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=block70
POSTGRES_USER=block70
POSTGRES_PASSWORD=block70password

# Optional: override FastAPI host/port when containerized
API_PORT=8000

# Frontend origin used for CORS in development
FRONTEND_ORIGIN=http://localhost:3000

# Public URL of the Next.js site (password reset links in emails). Production: https://block70.com
# Falls back to the first entry in FRONTEND_ORIGIN if unset.
BLOCK70_PUBLIC_URL=http://localhost:3000

# AI intelligence: FastAPI calls the Next.js Crypto-on-the-hour JSON route when set.
# Use the same origin you use for the web app (no trailing slash). NEXT_PUBLIC_SITE_URL is a fallback key.
INTERNAL_WEB_BASE_URL=http://localhost:3000
# Optional; if you add auth on /api/crypto-on-the-hour/intelligence, send the same value in X-Crypto-Hour-Intel-Secret.
CRYPTO_HOUR_INTEL_SECRET=

# Outbound email (password reset, alert delivery). Without SMTP_HOST, those features skip sending.
# STARTTLS on 587 (default): leave SMTP_SSL unset or false.
# Implicit TLS on 465: SMTP_SSL=true and SMTP_PORT=465
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
# From address (must be allowed by your provider / domain SPF/DKIM)
SMTP_FROM=noreply@yourdomain.com

