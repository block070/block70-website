# PostgreSQL (use host port 5433 when docker-compose maps 5433:5432)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/crypto_on_the_hour

# Redis (BullMQ). If docker-compose maps Redis to 6380 on the host, use port 6380 below.
REDIS_URL=redis://127.0.0.1:6380

# OpenAI
OPENAI_API_KEY=sk-...

# App
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4001

# Publishing — URL must be reachable FROM the worker process (not only from your browser).
# Same VPS as Next on host port 3001: http://127.0.0.1:3001/api/publish/crypto-on-the-hour
# Worker inside Docker, Next on host: http://host.docker.internal:3001/api/publish/crypto-on-the-hour (Linux: extra_hosts host-gateway)
# Public: https://your-domain/api/publish/crypto-on-the-hour
WEBSITE_PUBLISH_WEBHOOK_URL=http://127.0.0.1:3000/api/publish/crypto-on-the-hour
# Must match WEBSITE_PUBLISH_SECRET in repo root ~/block70/.env (docker web) or apps/web/.env.local (local Next).
WEBSITE_PUBLISH_SECRET=dev-crypto-hour-publish-rotate-after-go-live
VIDEO_GENERATION_WEBHOOK_URL=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# Pipeline
TOPIC_LOOKBACK_HOURS=24
MIN_TOPIC_SCORE_TO_GENERATE=3
OPENAI_MODEL=gpt-4o-mini
# IANA tz for BullMQ hourly cron (:00 each hour). Default US Central (CST/CDT).
PIPELINE_CRON_TZ=America/Chicago

# Optional: require header X-Admin-Secret for POST /admin/trigger-hourly
ADMIN_TRIGGER_SECRET=

# Optional observability
SENTRY_DSN=
SLACK_WEBHOOK_URL=
