# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crypto_on_the_hour

# Redis (BullMQ)
REDIS_URL=redis://127.0.0.1:6379

# OpenAI
OPENAI_API_KEY=sk-...

# App
NODE_ENV=development
API_HOST=0.0.0.0
API_PORT=4001

# Publishing (optional)
# Full URL to Block70 Next.js ingest, e.g. https://your-domain.com/api/publish/crypto-hour
WEBSITE_PUBLISH_WEBHOOK_URL=
# Must match WEBSITE_PUBLISH_SECRET on apps/web
WEBSITE_PUBLISH_SECRET=
VIDEO_GENERATION_WEBHOOK_URL=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=

# Pipeline
TOPIC_LOOKBACK_HOURS=24
MIN_TOPIC_SCORE_TO_GENERATE=3
OPENAI_MODEL=gpt-4o-mini

# Optional: require header X-Admin-Secret for POST /admin/trigger-hourly
ADMIN_TRIGGER_SECRET=

# Optional observability
SENTRY_DSN=
SLACK_WEBHOOK_URL=
