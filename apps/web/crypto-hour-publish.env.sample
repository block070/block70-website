# Merge these into apps/web/.env.local (or copy-paste), then restart `npm run start`.
# Rotate WEBSITE_PUBLISH_SECRET before production; must match apps/crypto-on-the-hour/.env

WEBSITE_PUBLISH_SECRET=dev-crypto-hour-publish-rotate-after-go-live
CRYPTO_HOUR_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/crypto_on_the_hour
