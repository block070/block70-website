# Optional: same Postgres as apps/crypto-on-the-hour (for /crypto-hour pages + webhook storage)
CRYPTO_HOUR_DATABASE_URL=

# Same secret as crypto-on-the-hour WEBSITE_PUBLISH_SECRET (X-Publish-Secret header)
WEBSITE_PUBLISH_SECRET=

# Consumer URL for coin-signals API proxy (optional)
CRYPTO_ON_THE_HOUR_URL=

# Site origin for server-side fetches (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
