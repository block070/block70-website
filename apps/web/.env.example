# Same Postgres as apps/crypto-on-the-hour (for /crypto-on-the-hour pages + webhook storage).
# Copy into .env.local; Docker default host port 5433 is shown in crypto-hour-publish.env.sample
# Docker block70-web: postgres://postgres:postgres@coh-postgres:5432/crypto_on_the_hour
CRYPTO_HOUR_DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/crypto_on_the_hour

# Must exactly match WEBSITE_PUBLISH_SECRET on the engine. Change after go-live.
WEBSITE_PUBLISH_SECRET=dev-crypto-hour-publish-rotate-after-go-live

# Consumer URL for coin-signals API proxy (optional)
CRYPTO_ON_THE_HOUR_URL=

# Site origin for server-side fetches (production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Prisma (required by prisma/schema.prisma). With plain Postgres (no pooler), set both to the same URL.
# DATABASE_URL="postgresql://block70:password@127.0.0.1:5432/block70"
# DIRECT_URL="postgresql://block70:password@127.0.0.1:5432/block70"

# Google Analytics 4 — Web data stream Measurement ID (public; set in Vercel/hosting env)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: absolute links in X posts (defaults to https://block70.com if unset)
CRYPTO_HOUR_PUBLIC_SITE_URL=

# Vercel Cron + manual: GET /api/cron/crypto-hour-x with Authorization: Bearer …
CRON_SECRET=

# X posting (OAuth 1.0a user context — “Read and write” keys from developer portal)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=
