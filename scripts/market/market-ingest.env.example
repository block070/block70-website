# Copy to /etc/block70/market-ingest.env on the NAS (chmod 600).
# Used by scripts/market/run_daily_bars_ingest.sh and systemd timer.

REPO_ROOT=/home/jmiller/block70-repo
MARKET_DATA_DATABASE_URL=postgresql+psycopg2://market:SECRET@192.168.0.180:5433/market

# Rolling refresh window (UTC calendar days)
MARKET_BARS_LOOKBACK_DAYS=3

# Alpaca (equity)
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
ALPACA_DATA_FEED=iex
ALPACA_BARS_CHUNK_DAYS=7
ALPACA_BARS_SLEEP=0.25

# Coinbase (crypto) — warehouse symbol list + exchange label
CRYPTO_BARS_EXCHANGE=COINBASE
