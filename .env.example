# Block70 - copy to .env and fill in values

# === PostgreSQL (Docker: postgres service) ===
POSTGRES_DB=block70
POSTGRES_USER=block70
POSTGRES_PASSWORD=block70password
POSTGRES_PORT=5432

# === Redis (Docker: redis service) ===
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379

# === API (Docker: api service) ===
# Override if API is exposed elsewhere
API_PORT=8000

# === Web (Docker: web service) ===
# Public URL of your API for browser requests (e.g. https://api.block70.com)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
WEB_PORT=3000

# === CORS - set to your production frontend origin ===
FRONTEND_ORIGIN=http://localhost:3000

# === Optional: CoinGecko (default free tier) ===
# COINGECKO_API_BASE=https://api.coingecko.com/api/v3

# === Optional: Sitemap base URL ===
SITEMAP_BASE_URL=https://block70.com

# === Optional: AI features (OpenAI) ===
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# === Optional: Stripe billing ===
# STRIPE_API_KEY=
# STRIPE_WEBHOOK_SECRET=

# === Optional: Auth ===
# JWT_SECRET_KEY=change-me-in-production
