POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=block70
POSTGRES_USER=block70
POSTGRES_PASSWORD=block70password

REDIS_HOST=redis
REDIS_PORT=6379

API_PORT=8000
# If Docker says "bind … :3000 … address already in use", set e.g. WEB_PORT=3001 (and fix FRONTEND_ORIGIN if needed)
WEB_PORT=3000

FRONTEND_ORIGIN=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Crypto-on-the-hour: webhook auth + same DB as the engine (for POST /api/publish/crypto-hour + /crypto-hour pages).
# Docker web container: use host.docker.internal if Postgres runs on the VPS host (e.g. mapped port 5433), not 127.0.0.1.
# WEBSITE_PUBLISH_SECRET must match apps/crypto-on-the-hour engine .env exactly.
# Docker: use coh-postgres (shared network block70_coh_edge). Local Next on host: 127.0.0.1:5433
CRYPTO_HOUR_DATABASE_URL=postgres://postgres:postgres@coh-postgres:5432/crypto_on_the_hour
WEBSITE_PUBLISH_SECRET=change-me-to-match-crypto-on-the-hour

# CoinMarketCap API – fallback for coins list pages 6–20. Get key at coinmarketcap.com/api
CMC_API_KEY=your-coinmarketcap-api-key
